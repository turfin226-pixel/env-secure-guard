generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db" // Removed env fallback
}

model Manga {
  id          String    @id @default(cuid())
  title       String
  author      String
  description String
  category    String
  cover       String
  pages       Page[]
  views       Int       @default(0)
  createdAt   DateTime  @default(now())
  comments    Comment[]
}

model Page {
  id       String @id @default(cuid())
  url      String
  order    Int
  mangaId  String
  manga    Manga  @relation(fields: [mangaId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String   @id @default(cuid())
  author    String
  text      String
  timestamp DateTime @default(now())
  mangaId   String
  manga     Manga    @relation(fields: [mangaId], references: [id], onDelete: Cascade)
}
